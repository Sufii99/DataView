<div class="devise-container">
  <div class="devise-form">
    <h2>Configurar Perfil</h2>
    
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.label :email %>
      <%= f.email_field :email, required: true %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p>Actualmente esperando confirmación para: <%= resource.unconfirmed_email %></p>
      <% end %>

      <%= f.label :password %> <i>(Déjalo en blanco si no quieres cambiarlo)</i>
      <%= f.password_field :password, autocomplete: "new-password" %>

      <% if @minimum_password_length %>
        <small><%= @minimum_password_length %> caracteres mínimo</small>
      <% end %>

      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>

      <%= f.label :current_password %> <i>(Necesario para confirmar los cambios)</i>
      <%= f.password_field :current_password, autocomplete: "current-password" %>

      <%= f.submit "Actualizar Perfil", class: "btn-primary" %>
    <% end %>

    <h3>Cancelar cuenta</h3>
    <div class="devise-links">
      <%= button_to "Eliminar cuenta", registration_path(resource_name), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn-danger" %>
    </div>

    <div class="devise-links">
      <%= link_to "Volver", root_path %>
    </div>
  </div>
</div>
